---
const today = new Date();
const formatter = new Intl.DateTimeFormat("zh-CN", {
	year: "numeric",
	month: "2-digit",
	day: "2-digit",
});
---

<footer>
	&copy; {formatter.format(today)}. WakeSunFlowerUp. All rights reserved.
</footer>
<style>
	footer {
		padding: 2em 1em 2em 1em;
		background: var(--footer-bg);
		color: rgb(var(--gray));
		text-align: center;
		transition: background 0.3s ease, color 0.3s ease;
	}
</style>

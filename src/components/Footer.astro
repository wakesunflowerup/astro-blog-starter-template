---
const today = new Date();
const formatter = new Intl.DateTimeFormat("zh-CN", {
	year: "numeric",
	month: "2-digit",
	day: "2-digit",
});
---

<footer id="footer">
	© {formatter.format(today)}. WakeSunFlowerUp. All rights reserved.
</footer>

<script>
	const formatter = new Intl.DateTimeFormat("zh-CN", {
		year: "numeric",
		month: "2-digit",
		day: "2-digit",
	});

	document.querySelector("#footer").textContent =
		`© ${formatter.format(new Date())}. WakeSunFlowerUp. All rights reserved.`;
</script>
